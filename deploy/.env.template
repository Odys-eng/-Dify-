# ============================================================
# .env.template
# ============================================================
# 文件路径：deploy/.env.template
# 用途：Dify 社区版 Docker Compose 部署的环境变量模板
# 使用方式：
#   1. 复制此文件到 dify/docker/.env（cp deploy/.env.template dify/docker/.env）
#   2. 填入实际值（所有 your_xxx_here 占位符）
#   3. 启动服务（./startup.sh 或 .\startup.ps1）
#
# 与 PRD 7.3 节对照：
#   ✅ 包含 DEEPSEEK_API_KEY、TAVILY_API_KEY
#   ✅ 包含 Dify URL 配置
#   ⚠️ 差异：PRD 7.4 写 http://localhost:3000，实际 Dify 通过 Nginx 80 端口访问
#      此处用 Dify 实际配置（http://localhost）
# ============================================================

# ------------------------------------------------------------
# 1. DeepSeek API 配置
# ------------------------------------------------------------
# 用途：LLM 推理服务，模型为 deepseek-v4-flash
# 获取方式：访问 https://platform.deepseek.com 注册 → 创建 API Key
# 费用：新用户送 ¥10 额度，demo 绰绰有余
# ⚠️ 重要：
#   1. 不要使用 deepseek-chat（2026-07-24 停用）
#   2. 此 Key 仍需在 Dify Web UI「设置 → 模型供应商 → DeepSeek」手动配置
#      此处作为配置记录和容器内环境变量
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ------------------------------------------------------------
# 2. Tavily 搜索 API 配置
# ------------------------------------------------------------
# 用途：联网搜索工具（知识库未命中时兜底）
# 获取方式：访问 https://tavily.com 注册 → 获取 API Key
# 免费额度：1000 次/月
# ⚠️ 此 Key 需在 Dify Web UI「自定义工具配置」时手动填入
TAVILY_API_KEY=your_tavily_api_key_here

# ------------------------------------------------------------
# 3. Dify 控制台与 API 地址
# ------------------------------------------------------------
# 本地部署默认通过 Nginx 80 端口访问
# ⚠️ 与 PRD 7.4 节差异：PRD 写 :3000，实际 Dify 通过 Nginx 80 暴露
CONSOLE_API_URL=http://localhost
CONSOLE_WEB_URL=http://localhost
SERVICE_API_URL=http://localhost
APP_WEB_URL=http://localhost

# 如果 80 端口被占用，修改此端口（同时需修改 nginx 配置）
EXPOSE_NGINX_PORT=80
EXPOSE_NGINX_SSL_PORT=443

# 单文件上传上限（MB），需大于知识库中最大的 28.3MB 设备手册
UPLOAD_FILE_SIZE_LIMIT=50

# ------------------------------------------------------------
# 4. Dify 基础配置（以下为 Dify 官方 .env.example 必填项）
# ------------------------------------------------------------

# 应用密钥（首次启动自动生成，请勿修改）
SECRET_KEY=

# 初始管理员密码（首次访问时设置，留空则在 Web UI 引导设置）
INIT_PASSWORD=

# 部署环境
DEPLOY_ENV=PRODUCTION

# ------------------------------------------------------------
# 5. 向量数据库配置（Weaviate - Dify 默认）
# ------------------------------------------------------------
VECTOR_STORE=weaviate
WEAVIATE_ENDPOINT=http://weaviate:8080

# ------------------------------------------------------------
# 6. 数据库配置（PostgreSQL - Dify 默认）
# ------------------------------------------------------------
DB_USERNAME=postgres
DB_PASSWORD=dify123456
DB_TYPE=postgresql
DB_HOST=db_postgres
DB_PORT=5432
DB_DATABASE=dify

# ------------------------------------------------------------
# 7. Redis 配置（Dify 默认）
# ------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------------------------------------------
# 8. 时区配置
# ------------------------------------------------------------
TZ=Asia/Shanghai
COMPOSE_PROFILES=${VECTOR_STORE:-weaviate},${DB_TYPE:-postgresql},collaboration
